    <EmbeddedResource Update="ReportText.*.resx">
      <DependentUpon>ReportText.resx</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="SelectionDescriptionText.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>SelectionDescriptionText.Designer.cs</LastGenOutput>
    </EmbeddedResource>
    <EmbeddedResource Update="SelectionDescriptionText.*.resx">
      <DependentUpon>SelectionDescriptionText.resx</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Resources\OcadToolbox\" />
  </ItemGroup>

</Project>
