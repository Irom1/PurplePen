  </ItemGroup>

  <ItemGroup>
    <Compile Update="CoreMiscText.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>CoreMiscText.resx</DependentUpon>
    </Compile>
    <Compile Update="ReportText.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>ReportText.resx</DependentUpon>
    </Compile>
    <Compile Update="ReportText.*.Designer.cs">
