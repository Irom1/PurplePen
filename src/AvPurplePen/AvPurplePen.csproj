<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <!-- app.manifest is a Windows-only artifact; skip it on other platforms to avoid build errors. -->
    <ApplicationManifest Condition="$([MSBuild]::IsOSPlatform('Windows'))">app.manifest</ApplicationManifest>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <DefineConstants>$(DefineConstants);PORTING</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <DefineConstants>$(DefineConstants);PORTING</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <Folder Include="Models\" />
    <AvaloniaResource Include="Assets\**" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\..\doc\userdocs\Help\Credits.htm">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>Help\Credits.htm</Link>
    </Content>
  </ItemGroup>

  <!-- Exclude ImageSharp from ReadyToRun — it grows from 1.7 MB to 30 MB
       and is only used for metadata/format detection, not on the hot path. -->
  <ItemGroup>
    <PublishReadyToRunExclude Include="SixLabors.ImageSharp.dll" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Semi.Avalonia" />

    <!--Condition below is needed to remove Avalonia.Diagnostics package from build output in Release configuration.-->
    <PackageReference Include="Avalonia.Diagnostics">
      <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
      <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="CommunityToolkit.Mvvm" />

    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />

    <PackageReference Include="Microsoft.VisualStudio.Threading.Analyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Avalonia\AvUtil\AvUtil.csproj" />
    <ProjectReference Include="..\MapModel\Graphics2D\Graphics2D.csproj" />
    <ProjectReference Include="..\MapModel\MapModel\MapModel.csproj" />
    <ProjectReference Include="..\MapModel\Map_PDF\Map_PDF.csproj" />
    <ProjectReference Include="..\MapModel\Map_SkiaStd\Map_SkiaStd.csproj" />
    <!-- PdfConverter is a standalone exe tool, not a compile-time dependency.
         Built via custom target below to avoid publish pipeline trying to
         resolve its outputs (which fails with ReadyToRun/RID-specific paths). -->
    <!--<ProjectReference Include="..\PdfConverter\PdfConverter.csproj" />-->
    <ProjectReference Include="..\PurplePenCore\PurplePenCore.csproj" />
    <ProjectReference Include="..\PurplePenViewModels\PurplePenViewModels.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="UIText.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>UIText.resx</DependentUpon>
    </Compile>
    <Compile Update="Views\Dialogs\SwitchLanguageDialog.axaml.cs">
      <DependentUpon>SwitchLanguageDialog.axaml</DependentUpon>
    </Compile>
    <Compile Update="UIText.*.Designer.cs">
      <DependentUpon>UIText.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="UIText.resx">
      <Generator>PublicResXFileCodeGenerator</Generator>
      <LastGenOutput>UIText.Designer.cs</LastGenOutput>
    </EmbeddedResource>
    <EmbeddedResource Update="UIText.*.resx">
      <DependentUpon>UIText.resx</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>
  <!-- Build PdfConverter as a standalone exe tool.
       Uses a direct MSBuild task instead of ProjectReference so the publish
       pipeline does not try to resolve PdfConverter's output files (which
       fails when PublishReadyToRun adds a RID-specific output path). -->
  <PropertyGroup>
    <!-- Framework-dependent (no-RID) build output — used during a regular Build. -->
    <PdfConverterBuildDir>..\PdfConverter\bin\$(Configuration)\net10.0\</PdfConverterBuildDir>
    <!-- RID-specific publish output — used when AvPurplePen is published with a RuntimeIdentifier. -->
    <PdfConverterPublishDir>..\PdfConverter\bin\$(Configuration)\net10.0\$(RuntimeIdentifier)\publish\</PdfConverterPublishDir>
  </PropertyGroup>

  <!-- Build PdfConverter (framework-dependent) before every Build. -->
  <Target Name="BuildPdfConverter" BeforeTargets="Build">
    <MSBuild Projects="..\PdfConverter\PdfConverter.csproj" Targets="Build" Properties="Configuration=$(Configuration);TargetFramework=net10.0;RuntimeIdentifier=;SelfContained=;PublishDir=;PublishReadyToRun=" />
  </Target>

  <!-- Publish PdfConverter before Publish.
       When a RuntimeIdentifier is set (e.g. osx-arm64) we publish PdfConverter with the
       same RID so that the correct platform-specific native libraries (PDFiumCore) are
       included.  For framework-dependent (no-RID) publishes we fall back to the regular
       Build output already produced by BuildPdfConverter. -->
  <Target Name="PublishPdfConverter" BeforeTargets="Publish">
    <MSBuild Projects="..\PdfConverter\PdfConverter.csproj" Targets="Publish"
             Condition="'$(RuntimeIdentifier)' != ''"
             Properties="Configuration=$(Configuration);TargetFramework=net10.0;RuntimeIdentifier=$(RuntimeIdentifier);SelfContained=$(SelfContained);PublishDir=$(PdfConverterPublishDir)" />
    <!-- For FDD publish (no RID) ensure we have an up-to-date build. -->
    <MSBuild Projects="..\PdfConverter\PdfConverter.csproj" Targets="Build"
             Condition="'$(RuntimeIdentifier)' == ''"
             Properties="Configuration=$(Configuration);TargetFramework=net10.0;RuntimeIdentifier=;SelfContained=;PublishDir=;PublishReadyToRun=" />
  </Target>

  <!-- Copy PdfConverter output to AvPurplePen output directory after Build. -->
  <Target Name="CopyPdfConverterToBuildOutput" AfterTargets="Build" DependsOnTargets="BuildPdfConverter">
    <ItemGroup>
      <!-- Use **/* (not **\*.*) so the extension-less Linux/macOS executable is included. -->
      <PdfConverterBuildFiles Include="$(PdfConverterBuildDir)**/*" />
    </ItemGroup>
    <Copy SourceFiles="@(PdfConverterBuildFiles)" DestinationFiles="@(PdfConverterBuildFiles->'$(OutputPath)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>

  <!-- Copy PdfConverter output to publish directory after Publish. -->
  <Target Name="CopyPdfConverterToPublishOutput" AfterTargets="Publish" DependsOnTargets="PublishPdfConverter">
    <PropertyGroup>
      <!-- When publishing with a RID, copy from the RID-specific publish output; otherwise use the build output. -->
      <_PdfConverterSourceDir Condition="'$(RuntimeIdentifier)' != ''">$(PdfConverterPublishDir)</_PdfConverterSourceDir>
      <!-- Fall back to the framework-dependent build output for FDD publishes or when RuntimeIdentifier is unset/whitespace. -->
      <_PdfConverterSourceDir Condition="'$(_PdfConverterSourceDir)' == ''">$(PdfConverterBuildDir)</_PdfConverterSourceDir>
    </PropertyGroup>
    <ItemGroup>
      <PdfConverterPublishFiles Include="$(_PdfConverterSourceDir)**/*" />
    </ItemGroup>
    <Copy SourceFiles="@(PdfConverterPublishFiles)" DestinationFiles="@(PdfConverterPublishFiles->'$(PublishDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>
</Project>
