<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:metadata="using:Avalonia.Metadata"
             xmlns:vm="using:PurplePen.ViewModels"
             xmlns:avutil="using:AvUtil"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
             x:Class="AvPurplePen.DescriptionViewer"
             x:DataType="vm:DescriptionViewerViewModel"
             
             DescriptionData="{Binding DescriptionData}">

    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
        <avutil:SkiaScrollableDrawingView x:Name="drawingView"
                                          LogicalExtent="1000,1000" />
    </ScrollViewer>
</UserControl>
