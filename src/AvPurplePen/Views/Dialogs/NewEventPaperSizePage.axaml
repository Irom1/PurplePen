<!--
    NewEventPaperSizePage.axaml
    Wizard page 5: Paper size, orientation and margin.
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PurplePen.ViewModels"
             xmlns:resx="using:AvPurplePen"
             x:Class="AvPurplePen.Views.NewEventPaperSizePage"
             x:DataType="vm:NewEventPaperSizePageViewModel">

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*"
          VerticalAlignment="Center">

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="{resx:Localize NewEventPaperSize_Prompt}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="{resx:Localize NewEventPaperSize_SizeLabel}"
                   VerticalAlignment="Center"
                   Margin="0,0,12,8"/>
        <ComboBox Grid.Row="1" Grid.Column="1"
                  ItemsSource="{Binding PaperSizeNames}"
                  SelectedIndex="{Binding SelectedPaperSizeIndex}"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="{resx:Localize NewEventPaperSize_MarginLabel}"
                   VerticalAlignment="Center"
                   Margin="0,0,12,8"/>
        <NumericUpDown Grid.Row="2" Grid.Column="1"
                       Value="{Binding MarginHundreths}"
                       Minimum="0"
                       Maximum="200"
                       FormatString="0"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,8"/>

        <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                  Content="{resx:Localize NewEventPaperSize_LandscapeLabel}"
                  IsChecked="{Binding Landscape}"/>

    </Grid>
</UserControl>
