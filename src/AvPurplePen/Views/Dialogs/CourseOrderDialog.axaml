<!--
    CourseOrderDialog.axaml
    Dialog for Course / Course Order command.
    Migrated from WinForms PurplePen/ChangeCourseOrder.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="AvPurplePen.Views.CourseOrderDialog"
        x:DataType="vm:CourseOrderDialogViewModel"
        Title="{resx:Localize ChangeCourseOrder_Text}"
        Icon="/Assets/transparent.ico"
        Width="400" Height="380"
        MinWidth="300" MinHeight="280"
        CanResize="True"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:CourseOrderDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Footer buttons -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button x:Name="cancelButton"
                        Content="{resx:Localize CancelButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
                <Button x:Name="okButton"
                        Content="{resx:Localize OKButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsDefault="True"
                        Click="OkButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Margin="16,12,16,8" Spacing="10">

            <TextBlock Text="{resx:Localize ChangeCourseOrder_courseOrderLabel_Text}"
                       TextWrapping="Wrap"/>

            <Grid ColumnDefinitions="*,Auto">

                <!-- Course list -->
                <ListBox Grid.Column="0"
                         ItemsSource="{Binding Courses}"
                         SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                         Height="240">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:CourseOrderItem">
                            <TextBlock Text="{Binding CourseName}" Padding="4,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Move Up / Move Down buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0"
                            Spacing="8">
                    <Button Content="{resx:Localize ChangeCourseOrder_moveUpButton_Text}"
                            Command="{Binding MoveUpCommand}"
                            IsEnabled="{Binding CanMoveUp}"
                            Width="90"
                            HorizontalContentAlignment="Center"/>
                    <Button Content="{resx:Localize ChangeCourseOrder_moveDownButton_Text}"
                            Command="{Binding MoveDownCommand}"
                            IsEnabled="{Binding CanMoveDown}"
                            Width="90"
                            HorizontalContentAlignment="Center"/>
                </StackPanel>

            </Grid>

        </StackPanel>
    </DockPanel>
</Window>
