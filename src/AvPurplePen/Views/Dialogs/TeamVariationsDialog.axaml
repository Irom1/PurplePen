<!--
    TeamVariationsDialog.axaml
    Dialog for Course / Relay Team Variations command.
    Migrated from WinForms PurplePen/TeamVariationsForm.cs.
    The HTML report is written to a temp file and opened in the system browser.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="AvPurplePen.Views.TeamVariationsDialog"
        x:DataType="vm:TeamVariationsDialogViewModel"
        Title="{resx:Localize TeamVariationsForm_Text}"
        Icon="/Assets/transparent.ico"
        Width="480" Height="400"
        CanResize="False"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:TeamVariationsDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Footer: Close button (always saves settings) -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button x:Name="exportButton"
                        Content="{resx:Localize TeamVariationsForm_buttonExport_Text}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        Click="ExportButton_Click"/>
                <Button x:Name="closeButton"
                        Content="{resx:Localize TeamVariationsForm_buttonClose_Text}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsDefault="True"
                        IsCancel="True"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Margin="16,12,16,8" Spacing="12">

            <!-- Parameters -->
            <HeaderedContentControl Header="{resx:Localize TeamVariationsForm_Text}">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{resx:Localize TeamVariationsForm_label2_Text}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,6"/>
                    <NumericUpDown Grid.Row="0" Grid.Column="1"
                                   Value="{Binding NumberOfLegs, Mode=TwoWay}"
                                   Minimum="1" Maximum="20"
                                   FormatString="0"
                                   HorizontalAlignment="Left"
                                   Width="80"
                                   Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{resx:Localize TeamVariationsForm_label1_Text}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,6"/>
                    <NumericUpDown Grid.Row="1" Grid.Column="1"
                                   Value="{Binding NumberOfTeams, Mode=TwoWay}"
                                   Minimum="0" Maximum="9999"
                                   FormatString="0"
                                   HorizontalAlignment="Left"
                                   Width="80"
                                   Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="{resx:Localize TeamVariationsForm_label3_Text}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,6"/>
                    <NumericUpDown Grid.Row="2" Grid.Column="1"
                                   Value="{Binding FirstTeamNumber, Mode=TwoWay}"
                                   Minimum="1" Maximum="99999"
                                   FormatString="0"
                                   HorizontalAlignment="Left"
                                   Width="80"
                                   Margin="0,0,0,6"/>

                    <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="{resx:Localize TeamVariationsForm_checkBoxHideVariationsFromMap_Text}"
                              IsChecked="{Binding HideVariationsOnMap, Mode=TwoWay}"/>

                </Grid>
            </HeaderedContentControl>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="calculateButton"
                        Content="{resx:Localize TeamVariationsForm_buttonCalculate_Text}"
                        Click="CalculateButton_Click"/>
                <Button x:Name="assignLegsButton"
                        Content="{resx:Localize TeamVariationsForm_fixedLegsLink_Text}"
                        Click="AssignLegsButton_Click"/>
            </StackPanel>

            <!-- Status / report summary -->
            <TextBlock Text="{Binding StatusText}"
                       TextWrapping="Wrap"
                       Foreground="#444444"/>

        </StackPanel>
    </DockPanel>
</Window>
