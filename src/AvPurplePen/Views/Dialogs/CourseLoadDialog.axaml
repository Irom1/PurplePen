<!--
    CourseLoadDialog.axaml
    Dialog for Course / Competitor Load command.
    Migrated from WinForms PurplePen/CourseLoad.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="AvPurplePen.Views.CourseLoadDialog"
        x:DataType="vm:CourseLoadDialogViewModel"
        Title="{resx:Localize CourseLoad_Text}"
        Icon="/Assets/transparent.ico"
        Width="400" Height="380"
        MinWidth="300" MinHeight="280"
        CanResize="True"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:CourseLoadDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Footer buttons -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button x:Name="cancelButton"
                        Content="{resx:Localize CancelButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
                <Button x:Name="okButton"
                        Content="{resx:Localize OKButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsDefault="True"
                        Click="OkButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Margin="16,12,16,8" Spacing="10">

            <TextBlock Text="{resx:Localize CourseLoad_courseLoadLabel_Text}"
                       TextWrapping="Wrap"/>

            <DataGrid ItemsSource="{Binding CourseLoads}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="False"
                      CanUserSortColumns="False"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      Height="240">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{resx:Localize CourseLoad_CourseName_HeaderText}"
                                        Binding="{Binding CourseName}"
                                        IsReadOnly="True"
                                        Width="2*"/>
                    <DataGridTextColumn Header="{resx:Localize CourseLoad_Load_HeaderText}"
                                        Binding="{Binding LoadText}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

        </StackPanel>
    </DockPanel>
</Window>
