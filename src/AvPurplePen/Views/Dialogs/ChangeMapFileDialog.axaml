<!--
    ChangeMapFileDialog.axaml
    Allows the user to pick a new map file and configure scale/DPI.
    Migrated from WinForms PurplePen/ChangeMapFile.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="440" d:DesignHeight="320"
        x:Class="AvPurplePen.Views.ChangeMapFileDialog"
        x:DataType="vm:ChangeMapFileDialogViewModel"
        Title="{resx:Localize ChangeMapFile_Text}"
        Icon="/Assets/transparent.ico"
        Width="440" Height="320"
        CanResize="False"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:ChangeMapFileDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- OK / Cancel row at bottom -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button x:Name="okButton"
                        Content="{resx:Localize OKButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsDefault="True"
                        IsEnabled="{Binding IsOkEnabled}"
                        Click="OkButton_Click"/>
                <Button Content="{resx:Localize CancelButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <StackPanel Margin="12,10,12,8" Spacing="10">

            <!-- Current map file label + display -->
            <TextBlock Text="{resx:Localize ChangeMapFile_mapFileDisplay_Text}"
                       FontWeight="Bold"/>

            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                <TextBox x:Name="mapFileNameTextBox"
                         Grid.Column="0"
                         Text="{Binding MapFile, Mode=TwoWay}"
                         IsReadOnly="True"
                         VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="{resx:Localize ChangeMapFile_buttonChooseFile_Text}"
                        Margin="6,0,0,0"
                        Click="ChooseFileButton_Click"/>
            </Grid>

            <!-- Error panel — shown when ValidateMapFile fails -->
            <Border IsVisible="{Binding ShowError}"
                    Background="#FFF0F0"
                    BorderBrush="#FF8080"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="8,6">
                <TextBlock x:Name="errorMessage"
                           Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap"
                           FontWeight="Bold"
                           Foreground="Red"/>
            </Border>

            <!-- Scale / DPI panel — shown for Bitmap and PDF map types -->
            <Grid IsVisible="{Binding ShowScaleDpi}"
                  ColumnDefinitions="Auto,Auto,Auto,Auto"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="6"
                  ColumnSpacing="6">

                <!-- Scale row -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{resx:Localize ChangeMapFile_labelScale_Text}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{resx:Localize ChangeMapFile_labelOneTo_Text}"
                           VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="2"
                           x:Name="textBoxScale"
                           Width="80"
                           Text="{Binding MapScaleText, Mode=TwoWay}"/>

                <!-- DPI row — only for Bitmap; use Opacity to preserve layout -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Opacity="{Binding ShowDpiOpacity}"
                           Text="{resx:Localize ChangeMapFile_labelDpi_Text}"
                           VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="2"
                           x:Name="textBoxDpi"
                           Width="80"
                           Opacity="{Binding ShowDpiOpacity}"
                           IsHitTestVisible="{Binding ShowDpi}"
                           Text="{Binding DpiText, Mode=TwoWay}"/>
                <TextBlock Grid.Row="1" Grid.Column="3"
                           Opacity="{Binding ShowDpiOpacity}"
                           Text="{resx:Localize ChangeMapFile_labelDpi2_Text}"
                           VerticalAlignment="Center"/>
            </Grid>

        </StackPanel>
    </DockPanel>
</Window>
