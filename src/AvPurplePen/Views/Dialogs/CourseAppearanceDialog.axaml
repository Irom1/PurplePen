<!--
    CourseAppearanceDialog.axaml
    Customize course symbology: item sizes, purple color, description color, and OCAD options.
    Migrated from WinForms PurplePen/CourseAppearanceDialog.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="680" d:DesignHeight="580"
        x:Class="AvPurplePen.Views.CourseAppearanceDialog"
        x:DataType="vm:CourseAppearanceDialogViewModel"
        Title="{resx:Localize CourseAppearanceDialog_Text}"
        Icon="/Assets/transparent.ico"
        Width="680" Height="580"
        CanResize="False"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:CourseAppearanceDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- OK / Cancel row at bottom -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button x:Name="okButton"
                        Content="{resx:Localize OKButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button x:Name="cancelButton"
                        Content="{resx:Localize CancelButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Bottom strip: description color + advanced (side by side) -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,*" Margin="8,0,8,8">

            <!-- Control Descriptions group -->
            <HeaderedContentControl Grid.Column="0"
                                    Header="{resx:Localize CourseAppearanceDialog_groupBox1_Text}"
                                    Margin="0,0,4,0">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto" Margin="8,4,8,8">
                    <TextBlock Grid.Column="0"
                               Text="{resx:Localize CourseAppearanceDialog_labelDescriptionColor_Text}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox x:Name="comboBoxDescriptionColor"
                              Grid.Column="1"
                              SelectedIndex="{Binding DescriptionColorIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="Black"/>
                        <ComboBoxItem Content="Purple"/>
                    </ComboBox>
                </Grid>
            </HeaderedContentControl>

            <!-- Advanced (OCAD overprint) group -->
            <HeaderedContentControl Grid.Column="1"
                                    Header="{resx:Localize CourseAppearanceDialog_groupBoxOcadMap_Text}"
                                    IsEnabled="{Binding UsesOcadMap}"
                                    Margin="4,0,0,0">
                <CheckBox x:Name="checkBoxOverprint"
                          Content="{resx:Localize CourseAppearanceDialog_checkBoxOverprint_Text}"
                          IsChecked="{Binding UseOcadOverprint, Mode=TwoWay}"
                          Margin="8,4,8,8"/>
            </HeaderedContentControl>
        </Grid>

        <!-- Main two-column area -->
        <Grid ColumnDefinitions="*,220" Margin="8,8,8,4">

            <!-- Left column: sizes + purple color -->
            <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,8,0">

                <!-- Item Sizes group -->
                <HeaderedContentControl Header="{resx:Localize CourseAppearanceDialog_groupBoxSizes_Text}">
                    <StackPanel Margin="8,4,8,8" Spacing="4">

                        <CheckBox x:Name="checkBoxStandardSizes"
                                  Content="{resx:Localize CourseAppearanceDialog_checkBoxStandardSizes_Text}"
                                  IsChecked="{Binding IsStandardSizes, Mode=TwoWay}"
                                  Click="CheckBoxStandardSizes_Click"/>

                        <!-- Custom size inputs — hidden (opacity=0) when standard sizes active -->
                        <Grid ColumnDefinitions="*,80,30"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="4"
                              Opacity="{Binding CustomSizesOpacity}"
                              IsHitTestVisible="{Binding IsCustomSizesHitTestVisible}">

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{resx:Localize CourseAppearanceDialog_labelControlCircle_Text}"
                                       VerticalAlignment="Center"/>
                            <NumericUpDown x:Name="upDownControlCircle"
                                           Grid.Row="0" Grid.Column="1"
                                           Value="{Binding ControlCircleDiameter, Mode=TwoWay}"
                                           Minimum="1.0" Maximum="50.0"
                                           Increment="0.1" FormatString="F2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="4,0,0,0"/>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{resx:Localize CourseAppearanceDialog_labelLineWidth_Text}"
                                       VerticalAlignment="Center"/>
                            <NumericUpDown x:Name="upDownLineWidth"
                                           Grid.Row="1" Grid.Column="1"
                                           Value="{Binding LineWidth, Mode=TwoWay}"
                                           Minimum="0.01" Maximum="10.0"
                                           Increment="0.01" FormatString="F2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="4,0,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="{resx:Localize CourseAppearanceDialog_labelCenterDot_Text}"
                                       VerticalAlignment="Center"/>
                            <NumericUpDown x:Name="upDownCenterDot"
                                           Grid.Row="2" Grid.Column="1"
                                           Value="{Binding CenterDotDiameter, Mode=TwoWay}"
                                           Minimum="0.0" Maximum="3.0"
                                           Increment="0.01" FormatString="F2"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="4,0,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="{resx:Localize CourseAppearanceDialog_labelControlNumber_Text}"
                                       VerticalAlignment="Center"/>
                            <NumericUpDown x:Name="upDownNumberHeight"
                                           Grid.Row="3" Grid.Column="1"
                                           Value="{Binding NumberHeight, Mode=TwoWay}"
                                           Minimum="1.0" Maximum="50.0"
                                           Increment="0.1" FormatString="F2"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </Grid>

                        <!-- Number style and other options are always visible -->
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{resx:Localize CourseAppearanceDialog_labelControlNumberStyle_Text}"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="comboBoxControlNumberStyle"
                                      Grid.Row="0" Grid.Column="1"
                                      SelectedIndex="{Binding ControlNumberStyleIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="Arial"/>
                                <ComboBoxItem Content="Arial Bold"/>
                                <ComboBoxItem Content="Roboto"/>
                                <ComboBoxItem Content="Roboto Bold"/>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{resx:Localize CourseAppearanceDialog_labelOutlineWidth_Text}"
                                       VerticalAlignment="Center"/>
                            <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,30">
                                <NumericUpDown x:Name="upDownOutlineWidth"
                                               Grid.Column="0"
                                               Value="{Binding OutlineWidth, Mode=TwoWay}"
                                               Minimum="0.0" Maximum="50.0"
                                               Increment="0.01" FormatString="F2"/>
                                <TextBlock Grid.Column="1" Text="mm" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </Grid>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="{resx:Localize CourseAppearanceDialog_labelAutoGapSize_Text}"
                                       VerticalAlignment="Center"/>
                            <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,30">
                                <NumericUpDown x:Name="upDownLegGapSize"
                                               Grid.Column="0"
                                               Value="{Binding LegGapSize, Mode=TwoWay}"
                                               Minimum="0.0" Maximum="50.0"
                                               Increment="0.1" FormatString="F2"/>
                                <TextBlock Grid.Column="1" Text="mm" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </Grid>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" RowSpacing="4">
                            <TextBlock Grid.Column="0"
                                       Text="{resx:Localize CourseAppearanceDialog_labelScaleItemSizes_Text}"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="comboBoxScaleItemSizes"
                                      Grid.Column="1"
                                      SelectedIndex="{Binding ScaleItemSizesIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="Do not scale"/>
                                <ComboBoxItem Content="Relative to map scale"/>
                                <ComboBoxItem Content="Relative to 1:15000"/>
                            </ComboBox>
                        </Grid>

                    </StackPanel>
                </HeaderedContentControl>

                <!-- Purple Color group -->
                <HeaderedContentControl Header="{resx:Localize CourseAppearanceDialog_groupBoxPurple_Text}">
                    <StackPanel Margin="8,4,8,8" Spacing="4">

                        <CheckBox x:Name="checkBoxDefaultPurple"
                                  Content="{resx:Localize CourseAppearanceDialog_checkBoxDefaultPurple_Text}"
                                  IsChecked="{Binding IsDefaultPurple, Mode=TwoWay}"
                                  Click="CheckBoxDefaultPurple_Click"/>

                        <!-- CMYK inputs — hidden when using map default purple -->
                        <Grid ColumnDefinitions="Auto,*,30"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              RowSpacing="4"
                              Opacity="{Binding CustomPurpleOpacity}"
                              IsHitTestVisible="{Binding IsCustomPurpleHitTestVisible}">

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{resx:Localize CourseAppearanceDialog_labelCyan_Text}" VerticalAlignment="Center" Width="80"/>
                            <NumericUpDown x:Name="upDownCyan" Grid.Row="0" Grid.Column="1"
                                           Value="{Binding PurpleCyan, Mode=TwoWay}"
                                           Minimum="0.0" Maximum="100.0" Increment="0.1" FormatString="F1"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="%" VerticalAlignment="Center" Margin="4,0,0,0"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{resx:Localize CourseAppearanceDialog_labelMagenta_Text}" VerticalAlignment="Center" Width="80"/>
                            <NumericUpDown x:Name="upDownMagenta" Grid.Row="1" Grid.Column="1"
                                           Value="{Binding PurpleMagenta, Mode=TwoWay}"
                                           Minimum="0.0" Maximum="100.0" Increment="0.1" FormatString="F1"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="%" VerticalAlignment="Center" Margin="4,0,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{resx:Localize CourseAppearanceDialog_labelYellow_Text}" VerticalAlignment="Center" Width="80"/>
                            <NumericUpDown x:Name="upDownYellow" Grid.Row="2" Grid.Column="1"
                                           Value="{Binding PurpleYellow, Mode=TwoWay}"
                                           Minimum="0.0" Maximum="100.0" Increment="0.1" FormatString="F1"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="%" VerticalAlignment="Center" Margin="4,0,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{resx:Localize CourseAppearanceDialog_labelBlack_Text}" VerticalAlignment="Center" Width="80"/>
                            <NumericUpDown x:Name="upDownBlack" Grid.Row="3" Grid.Column="1"
                                           Value="{Binding PurpleBlack, Mode=TwoWay}"
                                           Minimum="0.0" Maximum="100.0" Increment="0.1" FormatString="F1"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="%" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </Grid>

                        <!-- Blend mode -->
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="4" Margin="0,4,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{resx:Localize CourseAppearanceDialog_labelBlendPurple_Text}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="comboBoxBlendPurple"
                                      Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding BlendPurpleOptions}"
                                      SelectedIndex="{Binding BlendPurpleIndex, Mode=TwoWay}"/>

                            <!-- Layer picker — hidden when not in Layer blend mode -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{resx:Localize CourseAppearanceDialog_labelChooseLayer_Text}"
                                       VerticalAlignment="Center"
                                       Opacity="{Binding MapLayerPickerOpacity}"/>
                            <ComboBox x:Name="comboBoxMapLayers"
                                      Grid.Row="1" Grid.Column="1"
                                      ItemsSource="{Binding MapLayerNames}"
                                      SelectedIndex="{Binding SelectedMapLayerIndex, Mode=TwoWay}"
                                      Opacity="{Binding MapLayerPickerOpacity}"
                                      IsHitTestVisible="{Binding IsMapLayerPickerHitTestVisible}"/>
                        </Grid>

                    </StackPanel>
                </HeaderedContentControl>

            </StackPanel>

            <!-- Right column: preview -->
            <HeaderedContentControl Grid.Column="1"
                                    Header="{resx:Localize CourseAppearanceDialog_groupBoxPreview_Text}"
                                    VerticalAlignment="Stretch">
                <Border x:Name="previewBorder"
                        Background="White"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>
            </HeaderedContentControl>

        </Grid>

    </DockPanel>
</Window>
