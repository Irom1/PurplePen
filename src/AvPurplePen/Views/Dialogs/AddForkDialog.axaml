<!--
    AddForkDialog.axaml
    Dialog for Add / Add Variation. Lets the user choose Fork or Loop and branch count.
    Migrated from WinForms PurplePen/AddForkDialog.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="400" d:DesignHeight="260"
        x:Class="AvPurplePen.Views.AddForkDialog"
        x:DataType="vm:AddForkDialogViewModel"
        Title="{resx:Localize AddForkDialog_Text}"
        Icon="/Assets/transparent.ico"
        Width="400" Height="260"
        CanResize="False"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:AddForkDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Footer buttons -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="{resx:Localize CancelButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
                <Button Content="{resx:Localize OKButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsDefault="True"
                        Click="OkButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Margin="16,12,16,8" Spacing="10">

            <TextBlock Text="{resx:Localize AddForkDialog_labelWhichType_Text}"
                       TextWrapping="Wrap"/>

            <!-- Fork / Loop radio buttons -->
            <StackPanel Spacing="4">
                <RadioButton Content="{resx:Localize AddForkDialog_radioButtonFork_Text}"
                             IsChecked="{Binding IsForkMode}"/>
                <RadioButton Content="{resx:Localize AddForkDialog_radioButtonLoop_Text}"
                             IsChecked="{Binding Loop, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Branch / Loop count row (label swaps via opacity) -->
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{resx:Localize AddForkDialog_labelNumberBranches_Text}"
                           Opacity="{Binding ForkModeOpacity}"
                           IsHitTestVisible="{Binding IsForkMode}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{resx:Localize AddForkDialog_labelNumberLoops_Text}"
                           Opacity="{Binding LoopModeOpacity}"
                           IsHitTestVisible="{Binding IsLoopMode}"
                           VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding BranchCountChoices}"
                          SelectedItem="{Binding NumberOfBranches, Mode=TwoWay}"
                          Width="70"/>
            </StackPanel>

            <!-- Dynamic summary -->
            <TextBlock Text="{Binding SummaryText}"
                       TextWrapping="Wrap"
                       FontStyle="Italic"/>

        </StackPanel>
    </DockPanel>
</Window>
