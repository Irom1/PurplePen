<!--
    PunchcardLayoutDialog.axaml
    Configures the punch card grid dimensions and box fill order.
    Migrated from WinForms PurplePen/PunchcardLayoutDialog.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="320" d:DesignHeight="300"
        x:Class="AvPurplePen.Views.PunchcardLayoutDialog"
        x:DataType="vm:PunchcardLayoutDialogViewModel"
        Title="{resx:Localize PunchcardLayoutDialog_Text}"
        Icon="/Assets/transparent.ico"
        Width="320" Height="300"
        CanResize="False"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:PunchcardLayoutDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- OK / Cancel -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button x:Name="okButton"
                        Content="{resx:Localize OKButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button x:Name="cancelButton"
                        Content="{resx:Localize CancelButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="12,10,12,8" Spacing="10">

            <!-- Size group -->
            <HeaderedContentControl Header="{resx:Localize PunchcardLayoutDialog_sizeGroupBox_Text}">
                <Grid ColumnDefinitions="Auto,80,Auto,80"
                      RowDefinitions="Auto"
                      Margin="8,6,8,8">
                    <TextBlock Grid.Column="0"
                               Text="{resx:Localize PunchcardLayoutDialog_columnsLabel_Text}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <NumericUpDown x:Name="colsUpDown"
                                   Grid.Column="1"
                                   Value="{Binding BoxesAcross, Mode=TwoWay}"
                                   Minimum="3" Maximum="20"
                                   Increment="1" FormatString="F0"/>
                    <TextBlock Grid.Column="2"
                               Text="{resx:Localize PunchcardLayoutDialog_rowsLabel_Text}"
                               VerticalAlignment="Center"
                               Margin="12,0,6,0"/>
                    <NumericUpDown x:Name="rowsUpDown"
                                   Grid.Column="3"
                                   Value="{Binding BoxesDown, Mode=TwoWay}"
                                   Minimum="1" Maximum="20"
                                   Increment="1" FormatString="F0"/>
                </Grid>
            </HeaderedContentControl>

            <!-- Box Order group: 2×2 grid of radio buttons with direction labels -->
            <HeaderedContentControl Header="{resx:Localize PunchcardLayoutDialog_boxOrderGroupBox_Text}">
                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="8"
                      ColumnSpacing="8"
                      Margin="8,6,8,8">

                    <!-- LR/BT -->
                    <RadioButton x:Name="orderLRBT"
                                 Grid.Row="0" Grid.Column="0"
                                 GroupName="PunchOrder"
                                 IsChecked="{Binding IsLRBT, Mode=TwoWay}">
                        <StackPanel>
                            <TextBlock Text="→ ↑" FontFamily="Courier New" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="Left→Right, Bottom→Top" TextWrapping="Wrap" FontSize="11"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- RL/BT -->
                    <RadioButton x:Name="orderRLBT"
                                 Grid.Row="0" Grid.Column="1"
                                 GroupName="PunchOrder"
                                 IsChecked="{Binding IsRLBT, Mode=TwoWay}">
                        <StackPanel>
                            <TextBlock Text="← ↑" FontFamily="Courier New" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="Right→Left, Bottom→Top" TextWrapping="Wrap" FontSize="11"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- LR/TB -->
                    <RadioButton x:Name="orderLRTB"
                                 Grid.Row="1" Grid.Column="0"
                                 GroupName="PunchOrder"
                                 IsChecked="{Binding IsLRTB, Mode=TwoWay}">
                        <StackPanel>
                            <TextBlock Text="→ ↓" FontFamily="Courier New" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="Left→Right, Top→Bottom" TextWrapping="Wrap" FontSize="11"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- RL/TB -->
                    <RadioButton x:Name="orderRLTB"
                                 Grid.Row="1" Grid.Column="1"
                                 GroupName="PunchOrder"
                                 IsChecked="{Binding IsRLTB, Mode=TwoWay}">
                        <StackPanel>
                            <TextBlock Text="← ↓" FontFamily="Courier New" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="Right→Left, Top→Bottom" TextWrapping="Wrap" FontSize="11"/>
                        </StackPanel>
                    </RadioButton>

                </Grid>
            </HeaderedContentControl>

        </StackPanel>
    </DockPanel>
</Window>
