<!--
    AutoNumberingDialog.axaml
    Dialog for Event / Auto Numbering.
    Migrated from WinForms PurplePen/AutoNumbering.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="440" d:DesignHeight="280"
        x:Class="AvPurplePen.Views.AutoNumberingDialog"
        x:DataType="vm:AutoNumberingDialogViewModel"
        Title="{resx:Localize AutoNumbering_Text}"
        Icon="/Assets/transparent.ico"
        Width="440" Height="280"
        CanResize="False"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:AutoNumberingDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Footer buttons -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="{resx:Localize CancelButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
                <Button Content="{resx:Localize OKButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsDefault="True"
                        Click="OkButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Margin="16,12,16,8" Spacing="10">

            <TextBlock Text="{resx:Localize AutoNumbering_automaticNumberingLabel_Text}"
                       TextWrapping="Wrap"/>

            <!-- Starting code row -->
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{resx:Localize AutoNumbering_startingCodeLabel_Text}"
                           VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding FirstCode, Mode=TwoWay}"
                               Minimum="31"
                               Maximum="999"
                               Width="90"
                               FormatString="0"
                               Increment="1"/>
            </StackPanel>

            <CheckBox Content="{resx:Localize AutoNumbering_disallowInvertibleCheckBox_Text}"
                      IsChecked="{Binding DisallowInvertibleCodes, Mode=TwoWay}"/>

            <!-- Existing controls group -->
            <HeaderedContentControl Header="{resx:Localize AutoNumbering_existingControlsGroupBox_Text}">
                <StackPanel Spacing="6">
                    <RadioButton Content="{resx:Localize AutoNumbering_newControlsOnlyRadioButton_Text}"
                                 IsChecked="{Binding !RenumberExisting}"/>
                    <RadioButton Content="{resx:Localize AutoNumbering_renumberExistingRadioButton_Text}"
                                 IsChecked="{Binding RenumberExisting, Mode=TwoWay}"/>
                </StackPanel>
            </HeaderedContentControl>

        </StackPanel>
    </DockPanel>
</Window>
