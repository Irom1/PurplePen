<!--
    ChangeAllCodesDialog.axaml
    DataGrid letting the user rename control codes; changed codes show in red.
    Migrated from WinForms PurplePen/ChangeAllCodes.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="400" d:DesignHeight="400"
        x:Class="AvPurplePen.Views.ChangeAllCodesDialog"
        x:DataType="vm:ChangeAllCodesDialogViewModel"
        Title="{resx:Localize ChangeAllCodes_Text}"
        Icon="/Assets/transparent.ico"
        Width="400" Height="400"
        CanResize="True"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:ChangeAllCodesDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- OK / Cancel row at bottom -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button x:Name="okButton"
                        Content="{resx:Localize OKButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button Content="{resx:Localize CancelButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <StackPanel DockPanel.Dock="Top" Margin="12,10,12,8" Spacing="8">
            <TextBlock Text="{resx:Localize ChangeAllCodes_changeControlCodesLabel_Text}"
                       TextWrapping="Wrap"/>

            <DataGrid x:Name="grid"
                      ItemsSource="{Binding Entries}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      IsReadOnly="False"
                      Height="280"
                      CellEditEnding="Grid_CellEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{resx:Localize ChangeAllCodes_OldCode_HeaderText}"
                                        Binding="{Binding OldCode}"
                                        IsReadOnly="True"
                                        Width="*"/>
                    <DataGridTextColumn Header="{resx:Localize ChangeAllCodes_NewCode_HeaderText}"
                                        Binding="{Binding NewCode}"
                                        IsReadOnly="False"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

    </DockPanel>
</Window>
