<!--
    LinePropertiesDialog.axaml
    Shared dialog for Add/Line, Add/Rectangle, Add/Ellipse, and
    Item/Change Line Appearance. Title and explanation are set from the ViewModel.
    Migrated from WinForms PurplePen/LinePropertiesDialog.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="380" d:DesignHeight="340"
        x:Class="AvPurplePen.Views.LinePropertiesDialog"
        x:DataType="vm:LinePropertiesDialogViewModel"
        Title="{Binding Title}"
        Icon="/Assets/transparent.ico"
        Width="380"
        SizeToContent="Height"
        CanResize="False"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:LinePropertiesDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- OK / Cancel at bottom -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="{resx:Localize OKButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button Content="{resx:Localize CancelButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <StackPanel Margin="12,10,12,8" Spacing="10">

            <!-- Explanation -->
            <TextBlock Text="{Binding Explanation}"
                       TextWrapping="Wrap"/>

            <!-- Properties grid -->
            <Grid ColumnDefinitions="Auto,*,Auto"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                  RowSpacing="8"
                  ColumnSpacing="8">

                <!-- Color -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{resx:Localize LinePropertiesDialog_label1_Text}"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                          SelectedIndex="{Binding ColorIndex}">
                    <ComboBoxItem>Purple</ComboBoxItem>
                    <ComboBoxItem>Lower Purple</ComboBoxItem>
                    <ComboBoxItem>Black</ComboBoxItem>
                </ComboBox>

                <!-- Line style — hidden for Rectangle (ShowLineKindOpacity) -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Opacity="{Binding ShowLineKindOpacity}"
                           Text="{resx:Localize LinePropertiesDialog_label2_Text}"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                          Opacity="{Binding ShowLineKindOpacity}"
                          IsHitTestVisible="{Binding ShowLineKind}"
                          SelectedIndex="{Binding LineKindIndex}">
                    <ComboBoxItem Content="{resx:Localize LinePropertiesDialog_comboBoxStyle_Items}"/>
                    <ComboBoxItem Content="{resx:Localize LinePropertiesDialog_comboBoxStyle_Items1}"/>
                    <ComboBoxItem Content="{resx:Localize LinePropertiesDialog_comboBoxStyle_Items2}"/>
                </ComboBox>

                <!-- Line width -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{resx:Localize LinePropertiesDialog_labelWidth_Text}"
                           VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="2" Grid.Column="1"
                               Value="{Binding LineWidth}"
                               Minimum="0.01" Maximum="20"
                               Increment="0.05"
                               FormatString="F2"/>
                <TextBlock Grid.Row="2" Grid.Column="2"
                           Text="{resx:Localize LinePropertiesDialog_labelWidthMm_Text}"
                           VerticalAlignment="Center"/>

                <!-- Gap size — shown for Double + Dashed -->
                <TextBlock Grid.Row="3" Grid.Column="0"
                           Opacity="{Binding ShowGapSizeOpacity}"
                           Text="{resx:Localize LinePropertiesDialog_labelGapSize_Text}"
                           VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="3" Grid.Column="1"
                               Opacity="{Binding ShowGapSizeOpacity}"
                               IsHitTestVisible="{Binding ShowGapSize}"
                               Value="{Binding GapSize}"
                               Minimum="0.01" Maximum="20"
                               Increment="0.05"
                               FormatString="F2"/>
                <TextBlock Grid.Row="3" Grid.Column="2"
                           Opacity="{Binding ShowGapSizeOpacity}"
                           Text="{resx:Localize LinePropertiesDialog_labelGapSizeMm_Text}"
                           VerticalAlignment="Center"/>

                <!-- Dash size — shown for Dashed only -->
                <TextBlock Grid.Row="4" Grid.Column="0"
                           Opacity="{Binding ShowDashSizeOpacity}"
                           Text="{resx:Localize LinePropertiesDialog_labelDashSize_Text}"
                           VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="4" Grid.Column="1"
                               Opacity="{Binding ShowDashSizeOpacity}"
                               IsHitTestVisible="{Binding ShowDashSize}"
                               Value="{Binding DashSize}"
                               Minimum="0.01" Maximum="50"
                               Increment="0.1"
                               FormatString="F1"/>
                <TextBlock Grid.Row="4" Grid.Column="2"
                           Opacity="{Binding ShowDashSizeOpacity}"
                           Text="{resx:Localize LinePropertiesDialog_labelDashSizeMm_Text}"
                           VerticalAlignment="Center"/>

                <!-- Corner radius — shown for Rectangle only -->
                <TextBlock Grid.Row="5" Grid.Column="0"
                           Opacity="{Binding ShowRadiusOpacity}"
                           Text="{resx:Localize LinePropertiesDialog_labelCornerRadius_Text}"
                           VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="5" Grid.Column="1"
                               Opacity="{Binding ShowRadiusOpacity}"
                               IsHitTestVisible="{Binding ShowRadius}"
                               Value="{Binding CornerRadius}"
                               Minimum="0" Maximum="20"
                               Increment="0.1"
                               FormatString="F1"/>
                <TextBlock Grid.Row="5" Grid.Column="2"
                           Opacity="{Binding ShowRadiusOpacity}"
                           Text="{resx:Localize LinePropertiesDialog_labelRadiusMm_Text}"
                           VerticalAlignment="Center"/>

            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
