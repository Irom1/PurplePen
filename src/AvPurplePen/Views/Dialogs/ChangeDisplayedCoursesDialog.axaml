<!--
    ChangeDisplayedCoursesDialog.axaml
    Choose which courses a special object (line, rectangle, etc.) is displayed on.
    Migrated from WinForms PurplePen/ChangeSpecialCourses.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="360" d:DesignHeight="320"
        x:Class="AvPurplePen.Views.ChangeDisplayedCoursesDialog"
        x:DataType="vm:ChangeDisplayedCoursesDialogViewModel"
        Title="{resx:Localize ChangeSpecialCourses_Text}"
        Icon="/Assets/transparent.ico"
        Width="360" Height="320"
        CanResize="False"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:ChangeDisplayedCoursesDialogViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- OK / Cancel row at bottom -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="{resx:Localize OKButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button Content="{resx:Localize CancelButton}"
                        Width="85"
                        HorizontalContentAlignment="Center"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <StackPanel Margin="12,10,12,8" Spacing="8">
            <TextBlock Text="{resx:Localize ChangeSpecialCourses_changeDisplayedCoursesLabel_Text}"
                       TextWrapping="Wrap"/>

            <ListBox ItemsSource="{Binding Courses}"
                     Height="210"
                     SelectionMode="Multiple">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CourseCheckItem">
                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                  Content="{Binding Name}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

    </DockPanel>
</Window>
