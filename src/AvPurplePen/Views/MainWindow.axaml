<!--
    MainWindow.axaml

    This is the "View" in the MVVM pattern — it defines the UI layout using XAML.

    Key concepts for newcomers:

    1. DATA CONTEXT: The Window's DataContext is set to a MainWindowViewModel instance
       (done in App.axaml.cs at startup). This means all {Binding ...} expressions
       in this file look for properties on that ViewModel.

    2. COMPILED BINDINGS: The x:DataType="vm:MainWindowViewModel" attribute enables
       compiled bindings, which are checked at compile time (typos become build errors
       instead of silent runtime failures). This is an Avalonia feature.

    3. COMMAND BINDING: Button.Command="{Binding SomeCommand}" connects the button
       click to an ICommand on the ViewModel. The [RelayCommand] source generator
       creates these commands automatically from methods in the ViewModel.

    4. PROPERTY BINDING: Text="{Binding Counter}" displays the value of the Counter
       property. When Counter changes, the UI updates automatically because the
       [ObservableProperty] generator fires PropertyChanged notifications.

    5. x:Static: References a static property on a class at compile time.
       We use it to pull localized strings from the UIText resource class
       (generated from UIText.resx). This keeps all user-visible text in the View
       layer (resource files), not in the ViewModel.

    6. StringFormat: Formats a bound value into a string. We use it with the
       Counter binding so the display reads "Counter: 5". The format string itself
       comes from UIText.resx via x:Static, enabling localization.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AvPurplePen.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AvPurplePen">

    <!-- Design.DataContext sets a dummy ViewModel for the XAML previewer in the IDE.
         It does NOT affect the runtime DataContext (that's set in App.axaml.cs). -->
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- StackPanel arranges its children vertically (by default) or horizontally.
         Here we center everything in the window. -->
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="20">

        <!-- Display the counter as "Counter: 5".
             We bind to Counter (an int on the ViewModel), and use StringFormat to wrap
             it in a localized format string from UIText.resx (e.g. "Counter: {0}").

             We use element syntax for the Binding (instead of the inline {Binding ...}
             shorthand) because StringFormat needs to reference a static resource via
             x:Static, which isn't supported inside the curly-brace shorthand. -->
        <TextBlock FontSize="48"
                   HorizontalAlignment="Center">
            <TextBlock.Text>
                <Binding Path="Counter"
                         StringFormat="{x:Static resx:UIText.CounterLabel}" />
            </TextBlock.Text>
        </TextBlock>

        <!-- A horizontal row of buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="20">

            <!-- Clicking this button invokes DecrementCounterCommand on the ViewModel.
                 The command was auto-generated by [RelayCommand] from the DecrementCounter() method.

                 The button text comes directly from UIText.resx via x:Static. This means
                 the text can be localized by adding translated .resx files (e.g. UIText.fr.resx)
                 without changing any code. -->
            <Button Content="{x:Static resx:UIText.DecrementButton}"
                    Command="{Binding DecrementCounterCommand}"/>

            <!-- Clicking this button invokes IncrementCounterCommand on the ViewModel.
                 The command was auto-generated by [RelayCommand] from the IncrementCounter() method.
                 Button text comes from UIText.resx via x:Static. -->
            <Button Content="{x:Static resx:UIText.IncrementButton}"
                    Command="{Binding IncrementCounterCommand}"/>

        </StackPanel>

    </StackPanel>

</Window>
